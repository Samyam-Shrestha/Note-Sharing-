# Frontend origin allowed by backend CORS (security: no wildcard origin).
FRONTEND_ORIGIN=http://localhost:3000
VITE_API_BASE_URL=http://localhost:4000

# Backend runtime
PORT=4000

# PostgreSQL credentials
POSTGRES_USER=notes_user
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=notes_db

# Security: SSL enforced in DB connection string.
DATABASE_URL=postgresql://notes_user:replace-with-strong-password@postgres:5432/notes_db?sslmode=require
PG_SSL_REJECT_UNAUTHORIZED=false

# Security: 32-byte hex key for AES-256-GCM encryption.
NOTE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Security: RS256 PEM keys (inject from secret manager/K8s secrets in production).
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"

# Optional pgAdmin local dev
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-with-strong-password
